{
  "name": "sudoverse",
  "private": true,
  "version": "0.2.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "bootstrap": "node scripts/build.js bootstrap",
    "setup:system": "node scripts/build.js setup-system",
    "dev:web": "npm --workspace @sudoku/web run dev",
    "build:web": "node scripts/build.js web",
    "build:desktop": "node scripts/build.js desktop",
    "build:android": "node scripts/build.js android",
    "build:flatpak": "node scripts/build.js flatpak",
    "build:all": "node scripts/build.js all",
    "dev:mobile": "npm --workspace @sudoku/mobile run start",
    "dev:desktop": "npm --workspace @sudoku/desktop run tauri:dev",
    "typecheck": "npm run -ws typecheck",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
