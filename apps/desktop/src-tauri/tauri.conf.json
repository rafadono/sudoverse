{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sudoku Platform",
  "version": "0.2.0",
  "identifier": "com.sudokuvariant.app",
  "build": {
    "beforeDevCommand": "npm --prefix ../.. --workspace @sudoku/web run dev",
    "beforeBuildCommand": "npm --prefix ../.. --workspace @sudoku/web run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sudoku Platform",
        "width": 1000,
        "height": 860,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm", "nsis", "msi"],
    "icon": []
  }
}
